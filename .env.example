# 绠＄悊鍛樺瘑鐮?ADMIN_PASSWORD=your_admin_password_here

# 鑵捐浜?COS 閰嶇疆
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-guangzhou

# Next.js 閰嶇疆
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# apihz.cn IP 归属地查询（访问统计 V2 用户列表地理位置）
# 接口：POST https://cn.apihz.cn/api/ip/chaapi.php，body 为 application/x-www-form-urlencoded（id、key、ip）
APIHZ_IP_ID=your_apihz_id
APIHZ_IP_KEY=your_apihz_key